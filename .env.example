# Copy to .env for local dev (never commit real values). In production,
# set these in Vercel → Project → Settings → Environment Variables.

# Your Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Optional: pin a model. Defaults to claude-sonnet-5 if unset.
# Use claude-haiku-4-5-20251001 for lower cost.
CLAUDE_MODEL=claude-sonnet-5

# Upstash Redis (upstash.com → create a Redis database → REST section)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# Optional: which child's data namespace to use (lets you add siblings later)
CHILD_ID=sterling
